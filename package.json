{
  "name": "karttapallo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "license": "Unlicense",
  "scripts": {
    "build:native": "clang++ -shared -fPIC -O2 -fobjc-arc -Wno-deprecated-declarations -framework Foundation -framework ImageIO -framework AVFoundation -framework CoreGraphics -framework CoreMedia -o resources/native/libkarttapallo.dylib resources/native/karttapallo-bridge.mm",
    "dev": "bun run build:native && bun run --hot src/server/dev.ts",
    "dev:app": "bun run build:native && electrobun build && electrobun dev",
    "build:app": "bun run build:native && electrobun build",
    "build:app:stable": "bun run build:native && electrobun build --env=stable",
    "install:app": "bun run build:app:stable && cp -r build/stable-macos-arm64/Karttapallo.app /Applications/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "bun test src resources/native",
    "test:watch": "bun test src resources/native --watch",
    "e2e": "NODE_NO_WARNINGS=1 playwright test",
    "e2e:headed": "NODE_NO_WARNINGS=1 E2E_HEADED=1 playwright test --headed",
    "e2e:install": "playwright install webkit"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playwright/test": "^1.60.0",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "1.3.14",
    "@types/geojson": "^7946.0.16",
    "@types/three": "^0.184.1",
    "eslint": "10.3.0",
    "eslint-config-love": "^154.0.0",
    "prettier": "3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@lit-labs/signals": "^0.2.0",
    "@lit/context": "^1.1.6",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "electrobun": "1.16.0",
    "geo-tz": "8.1.7",
    "lit": "^3.3.2",
    "maplibre-gl": "5.24.0"
  }
}
